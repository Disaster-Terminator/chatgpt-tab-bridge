{
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowImportingTsExtensions": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/extension/**/*.ts", "src/extension/**/*.d.ts"]
}

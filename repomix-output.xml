    expectedHopId: "s8-r4-hop9"
  });
  const gate = evaluateSubmissionAcceptanceGate(verification);

  assert.equal(gate.acceptedEquivalentEvidence, false);
  assert.equal(gate.waitingReplyAllowed, false);

  const intervalId = setInterval(() => {
    try {
      port.postMessage({
        type: "heartbeat"
      });
    } catch {
      clearInterval(intervalId);
    }
  }, 20000);

  port.onDisconnect.addListener(() => {
    clearInterval(intervalId);
    keepAlivePort = null;

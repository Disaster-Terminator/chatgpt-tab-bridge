<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ChatGPT Bridge</title>
    <link rel="stylesheet" href="popup.css" />
  </head>
  <body>
    <main class="popup">
      <header class="popup__header">
        <div>
          <p class="popup__eyebrow" data-copy="eyebrow">ChatGPT Bridge</p>
          <h1 class="popup__title" data-copy="title">设置</h1>
          <p class="popup__subtitle">总览、设置与调试入口</p>
        </div>
        <span class="popup__badge" id="phaseBadge" data-phase="idle">idle</span>
      </header>

      <section class="popup__section">
        <div class="popup__section-header">
          <div>
            <p class="popup__section-label" data-copy="sectionGlobalStatus">全局状态</p>
            <h2 class="popup__section-title">Bridge</h2>
            <p class="popup__section-hint">仅负责全局概览与低频控制。</p>
          </div>
        </div>
        <div class="popup__row">
          <div class="popup__meta">
            <span data-copy="roundLabel">轮次</span>
            <strong id="roundValue">0</strong>
            <span class="popup__dot"></span>
            <span data-copy="nextHopLabel">下一跳</span>
            <strong id="nextHopValue">A → B</strong>
          </div>
        </div>
        <div class="popup__step-card">
          <div class="popup__step-header">
            <span class="popup__step-dot"></span>
            <span data-copy="currentStepLabel">步骤</span>
          </div>
          <p class="popup__step-value" id="currentStepValue">idle</p>
          <div class="popup__issue-row" id="issueRow" hidden>
            <span id="issueValue">-</span>
          </div>
          <div class="popup__readiness-row" id="readinessRow" hidden>
            <span class="popup__readiness-label" data-copy="readinessLabel">无法启动:</span>
            <span class="popup__readiness-reason" id="readinessReason">-</span>
          </div>
        </div>
        <div class="popup__binding-grid">
          <div class="popup__binding-card">
            <p class="popup__binding-label" data-copy="bindingA">绑定 A</p>
            <p class="popup__binding-value" id="bindingA">未绑定</p>
          </div>
          <div class="popup__binding-card">
            <p class="popup__binding-label" data-copy="bindingB">绑定 B</p>
            <p class="popup__binding-value" id="bindingB">未绑定</p>
          </div>
        </div>
        <div class="popup__current-tab-card">
          <p class="popup__binding-label" data-copy="currentTab">当前标签页</p>
          <p class="popup__binding-value" id="currentTabStatus">-</p>
        </div>
      </section>

      <section class="popup__section">
        <p class="popup__section-label" data-copy="sectionSettings">设置</p>
        <label class="popup__label" for="localeSelect">语言</label>
        <select class="popup__select" id="localeSelect">
          <option value="zh-CN">中文</option>
          <option value="en">English</option>
        </select>
        <div class="popup__toggle-row">
          <span data-copy="labelEnableOverlay">启用悬浮窗</span>
          <label class="popup__toggle" data-checked="true">
            <input type="checkbox" class="popup__toggle-input" id="overlayEnabledCheckbox" checked />
            <span class="popup__toggle-knob"></span>
          </label>
        </div>
        <div class="popup__toggle-row">
          <span data-copy="labelDefaultExpanded">默认展开</span>
          <label class="popup__toggle" data-checked="true">
            <input type="checkbox" class="popup__toggle-input" id="defaultExpandedCheckbox" checked />
            <span class="popup__toggle-knob"></span>
          </label>
        </div>
        <div class="popup__action-row">
          <button type="button" class="popup__btn" id="resetOverlayPositionButton" data-copy="resetPosition">重置悬浮窗位置</button>
        </div>
      </section>

      <section class="popup__section">
        <p class="popup__section-label" data-copy="sectionFallback">备用操作</p>
        <label class="popup__label" for="starterSelect">起始侧</label>
        <select class="popup__select" id="starterSelect">
          <option value="A">A 起始</option>
          <option value="B">B 起始</option>
        </select>
        <label class="popup__label" for="overrideSelect">暂停态下一跳覆盖</label>
        <select class="popup__select" id="overrideSelect">
          <option value="">不覆盖</option>
          <option value="A">A → B</option>
          <option value="B">B → A</option>
        </select>
        <div class="popup__action-row">
          <button type="button" class="popup__btn" id="clearTerminalButton" data-copy="clearTerminal">清空终端</button>
          <button type="button" class="popup__btn" id="openHelpButton" data-copy="openHelp">帮助</button>
        </div>
        <!-- Compat layer: retained for smoke test, hidden from main visual flow -->
        <div class="popup__compat-row" id="compatControls" hidden>
          <button type="button" class="popup__btn popup__btn--primary" id="startButton" data-copy="start">开始</button>
          <button type="button" class="popup__btn" id="pauseButton" data-copy="pause">暂停</button>
          <button type="button" class="popup__btn" id="resumeButton" data-copy="resume">恢复</button>
          <button type="button" class="popup__btn" id="stopButton" data-copy="stop">停止</button>
          <button type="button" class="popup__btn" id="bindAButton" data-copy="bindA">绑定 A</button>
          <button type="button" class="popup__btn" id="bindBButton" data-copy="bindB">绑定 B</button>
        </div>
      </section>

      <details class="popup__details" open>
        <summary class="popup__details-summary">
          <span data-copy="sectionDebug">调试</span>
        </summary>
        <div class="popup__details-content">
          <div class="popup__debug-row">
            <span data-copy="currentStepLabel">步骤</span>
            <span id="currentStepValueDebug">-</span>
          </div>
          <div class="popup__debug-row">
            <span data-copy="lastIssueLabel">问题</span>
            <span id="issueValueDebug">-</span>
          </div>
          <div class="popup__debug-row">
            <span data-copy="transportLabel">传输</span>
            <span id="transportValue">-</span>
          </div>
          <div class="popup__debug-row">
            <span data-copy="selectorLabel">选择器</span>
            <span id="selectorValue">-</span>
          </div>
          <button type="button" class="popup__btn" id="copyDebugButton" data-copy="copyDebug">复制调试快照</button>
          <div id="copyFeedback" class="popup__copy-feedback" hidden></div>
        </div>
      </details>
    </main>
    <script type="module" src="popup.mjs"></script>
  </body>
</html>
